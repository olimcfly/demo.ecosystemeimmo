Options -Indexes
RewriteEngine On

# ==============================

# 🔐 BLOQUER FICHIERS SENSIBLES

# ==============================

<FilesMatch "^.|.env|.git|composer.(json|lock)|package.json|.sql|.log">
Require all denied </FilesMatch>

# ==============================

# 🔐 BLOQUER ACCÈS DIRECT AUX DOSSIERS SENSIBLES

# ==============================

RewriteRule ^config(/.*)?$    - [F,L]
RewriteRule ^includes(/.*)?$  - [F,L]
RewriteRule ^logs(/.*)?$      - [F,L]

# ==============================

# ✅ AUTORISATIONS SPÉCIALES

# ==============================

# Import templates

RewriteCond %{REQUEST_URI} ^/admin/modules/system/templates/import-16-templates.php$
RewriteRule ^ - [L]

# Diagnostic modules

RewriteCond %{REQUEST_URI} ^/admin/modules/.*/diagnostic.php$
RewriteRule ^ - [L]

# ==============================

# 📁 FICHIERS EXISTANTS

# ==============================

RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ==============================

# 🚀 ROUTING ADMIN

# ==============================

# login

RewriteRule ^login/?$    auth/login.php [L]
RewriteRule ^logout/?$   auth/logout.php [L]

# modules dynamiques

RewriteRule ^modules/([a-zA-Z0-9_-]+)/?$ modules/$1/index.php [L]
RewriteRule ^modules/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/?$ modules/$1/$2.php [L]

# fallback dashboard

RewriteRule ^$ dashboard.php [L]

# ==============================

# 🚨 ERREURS

# ==============================

ErrorDocument 404 /admin/dashboard.php
