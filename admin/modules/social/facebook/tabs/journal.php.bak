                    <div style="font-weight: 500;"><?php echo date('d/m/Y', strtotime($post['scheduled_date'])); ?></div>
                    <div style="font-size: 11px; color: #64748b;">
                        <?php 
                        $daysAgo = (strtotime('today') - strtotime($post['scheduled_date'])) / 86400;
