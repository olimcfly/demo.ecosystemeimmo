<?php
/**
 * TAB: Journal des Publications Facebook
 * Historique par Persona avec filtres
 */

$filterPersona = $_GET['persona'] ?? '';
$filterType = $_GET['type'] ?? '';
$filterStatus = $_GET['status'] ?? '';

// Construction de la requête
$sql = "SELECT fp.*, np.name as persona_name, np.type as persona_type 
        FROM facebook_posts fp 
        LEFT JOIN neuropersonas np ON fp.persona_id = np.id 
        WHERE 1=1";
$params = [];

if ($filterPersona) {
    $sql .= " AND fp.persona_id = ?";
    $params[] = $filterPersona;
}
if ($filterType) {
    $sql .= " AND fp.post_type = ?";
    $params[] = $filterType;
}
if ($filterStatus) {
    $sql .= " AND fp.status = ?";
    $params[] = $filterStatus;
}

$sql .= " ORDER BY fp.scheduled_date DESC, fp.created_at DESC";

$posts = [];
try {
    $stmt = $pdo->prepare($sql);
    $stmt->execute($params);
    $posts = $stmt->fetchAll();
} catch (Exception $e) {}

// Stats par persona
$statsByPersona = [];
try {
    $stmt = $pdo->query("
        SELECT np.id, np.name, np.type, COUNT(fp.id) as post_count, 
               SUM(CASE WHEN fp.status = 'published' THEN 1 ELSE 0 END) as published_count
        FROM neuropersonas np
        LEFT JOIN facebook_posts fp ON np.id = fp.persona_id
        WHERE np.is_active = 1
        GROUP BY np.id
        ORDER BY np.type, np.name
    ");
    $statsByPersona = $stmt->fetchAll();
} catch (Exception $e) {}
?>

<!-- Stats par Persona -->
<div style="margin-bottom: 24px;">
    <h4 style="font-size: 14px; font-weight: 600; color: #64748b; margin-bottom: 12px;">
        <i class="fas fa-chart-bar"></i> Publications par Persona
    </h4>
    <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <?php if (empty($statsByPersona)): ?>
        <div style="color: #64748b; font-size: 13px;">
            <i class="fas fa-info-circle"></i> Aucun persona configuré. 
            <a href="?page=neuropersona" style="color: #1877f2;">Créez vos personas</a>
        </div>
        <?php else: ?>
        <?php foreach ($statsByPersona as $ps): ?>
        <a href="?page=facebook&tab=journal&persona=<?php echo $ps['id']; ?>" 
           class="persona-stat-card <?php echo $filterPersona == $ps['id'] ? 'active' : ''; ?>"
           style="<?php echo $ps['type'] === 'acheteur' ? 'border-color: #3b82f6;' : 'border-color: #ec4899;'; ?>">
            <span class="persona-badge <?php echo $ps['type']; ?>">
                <?php echo $ps['type'] === 'acheteur' ? '🏠' : '🔑'; ?>
                <?php echo htmlspecialchars($ps['name']); ?>
            </span>
            <div class="persona-stats">
                <span><strong><?php echo $ps['post_count'] ?: 0; ?></strong> posts</span>
                <span style="color: #10b981;"><i class="fas fa-check"></i> <?php echo $ps['published_count'] ?: 0; ?></span>
            </div>
        </a>
        <?php endforeach; ?>
        <?php endif; ?>
    </div>
</div>

<!-- Filtres -->
