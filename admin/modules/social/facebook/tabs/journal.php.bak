    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        <a href="?page=facebook&tab=journal" class="btn btn-sm <?php echo !$filterPersona && !$filterType && !$filterStatus ? 'btn-fb' : 'btn-secondary'; ?>">
            Tout
