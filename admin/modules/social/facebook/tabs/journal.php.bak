               style="<?php echo $filterType === 'connecter' ? 'background: #f59e0b; color: white;' : ''; ?>">
                <i class="fas fa-heart"></i> Connecter
            </a>
            <a href="?page=facebook&tab=journal&type=convertir<?php echo $filterPersona ? '&persona='.$filterPersona : ''; ?>" 
               class="btn btn-sm <?php echo $filterType === 'convertir' ? '' : 'btn-secondary'; ?>"
               style="<?php echo $filterType === 'convertir' ? 'background: #8b5cf6; color: white;' : ''; ?>">
                <i class="fas fa-bullseye"></i> Convertir
            </a>
        </div>
        <div style="display: flex; gap: 4px;">
            <a href="?page=facebook&tab=journal&status=planned<?php echo $filterPersona ? '&persona='.$filterPersona : ''; ?>" 
               class="btn btn-sm <?php echo $filterStatus === 'planned' ? 'btn-fb' : 'btn-secondary'; ?>">
                <i class="fas fa-clock"></i> Planifiés
            </a>
            <a href="?page=facebook&tab=journal&status=published<?php echo $filterPersona ? '&persona='.$filterPersona : ''; ?>" 
               class="btn btn-sm <?php echo $filterStatus === 'published' ? 'btn-success' : 'btn-secondary'; ?>">
                <i class="fas fa-check"></i> Publiés
            </a>
        </div>
    </div>
    <a href="?page=facebook&tab=rediger" class="btn btn-primary">
        <i class="fas fa-plus"></i> Nouvelle publication
    </a>
</div>

<?php if (empty($posts)): ?>
<div class="content-card">
    <div class="card-body" style="text-align: center; padding: 60px;">
        <i class="fab fa-facebook" style="font-size: 48px; color: #e2e8f0; margin-bottom: 16px;"></i>
